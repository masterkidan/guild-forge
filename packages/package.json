{
  "name": "@guild-forge/root",
  "private": true,
  "workspaces": [
    "webhook-gateway",
    "queue-service",
    "dispatcher",
    "registry",
    "agent-executor",
    "scheduler",
    "shared"
  ],
  "scripts": {
    "build": "bun run build --filter \"*\"",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "dev": "bun run dev --filter \"*\"",
    "seed": "bun run ../scripts/seed-manifests.ts",
    "typecheck": "bun run typecheck --filter \"*\""
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
